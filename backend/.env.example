LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
DATABASE_URL=sqlite:///./atoms_demo.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth (local mode works out of the box)
APP_ENV=development
AUTH_MODE=local
JWT_SECRET=change-me-in-production

# Supabase (optional — set AUTH_MODE=supabase when configured)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=atoms-demo

# Demo account (auto-seeded on startup)
DEMO_EMAIL=demo@atoms.demo
DEMO_PASSWORD=demo123456
